MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/?retryWrites=true&w=majority
MONGO_DB_NAME=timetable_jayanth
JWT_SECRET=replace-with-a-long-random-secret
CORS_ORIGINS=http://localhost:5173,https://your-frontend.pages.dev,https://your-custom-domain.com
SOLVER_URL=https://your-solver-service.onrender.com
SOLVER_TIMEOUT_MS=210000
JWT_EXPIRES_IN=1h
NODE_ENV=development
PORT=5000

# AWS EC2 Control (only used in production when NODE_ENV=production)
# Get these from AWS IAM Console -> Security Credentials
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_REGION=eu-north-1
# Your EC2 instance ID (i-xxxxxxxx format)
EC2_INSTANCE_ID=i-xxxxxxxxxxxxxxxxx
